<?xml version="1.0"?>
<ruleset name="Internete GMB Reviews — Security">
    <description>Security-focused rules only. Errors here BLOCK the release.</description>

    <file>.</file>

    <exclude-pattern>vendor/*</exclude-pattern>

    <config name="minimum_supported_wp_version" value="5.8"/>

    <!-- XSS: all output must be escaped -->
    <rule ref="WordPress.Security.EscapeOutput"/>

    <!-- SQL: dynamic values in queries must use $wpdb->prepare() -->
    <rule ref="WordPress.DB.PreparedSQL"/>
    <rule ref="WordPress.DB.PreparedSQLPlaceholders"/>
    <!-- WordPress.DB.DirectDatabaseQuery excluded: $wpdb calls are standard in plugins -->

    <!-- CSRF: nonce verification on form/AJAX actions -->
    <rule ref="WordPress.Security.NonceVerification"/>

    <!-- Input: user input must be sanitized -->
    <rule ref="WordPress.Security.ValidatedSanitizedInput"/>

    <!-- No eval() or dangerous PHP functions -->
    <rule ref="Squiz.PHP.Eval"/>
    <rule ref="WordPress.PHP.DiscouragedPHPFunctions"/>
</ruleset>
